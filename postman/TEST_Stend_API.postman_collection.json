				{
					"name": "🔧 Setup: promote to ADMIN",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Для тестирования админ-эндпоинтов нужен токен с ролью ADMIN.",
									"// Прямой вызов /api/admin/users/{id}/role требует ADMIN — курица и яйцо.",
									"// Этот запрос использует прямой auth-service URL для обхода gateway-проверки,",
									"// но SecurityConfig тоже требует hasRole(ADMIN).",
									"// Решение: заранее создать админа через H2 Console или скрипт.",
									"// Здесь предполагаем, что admin_token уже задан в переменных окружения.",
									"if (!pm.environment.get('admin_token') && !pm.collectionVariables.get('admin_token')) {",
									"    console.warn('⚠ admin_token не задан. Установите переменную admin_token с JWT роли ADMIN.');",
									"}"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.test('Role changed to ADMIN', () => pm.expect(json.role).to.eql('ADMIN'));",
									"    pm.collectionVariables.set('admin_token', pm.collectionVariables.get('auth_token'));",
									"} else {",
									"    console.warn('⚠ Не удалось повысить роль. Установите admin_token вручную.');",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }]
						},
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "\"ADMIN\""
						},
						"url": {
							"raw": "{{base_url}}/api/admin/users/{{user_id}}/role",
							"host": ["{{base_url}}"],
							"path": ["api", "admin", "users", "{{user_id}}", "role"]
						}
					}
				},
				{
					"name": "List users — as ADMIN (200)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"",
									"const json = pm.response.json();",
									"pm.test('Response is array', () => pm.expect(json).to.be.an('array'));",
									"pm.test('Array not empty', () => pm.expect(json.length).to.be.greaterThan(0));",
									"",
									"const user = json.find(u => u.id === Number(pm.collectionVariables.get('user_id')));",
									"if (user) {",
									"    pm.test('Found our user', () => pm.expect(user.username).to.eql(pm.collectionVariables.get('test_username')));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }]
						},
						"method": "GET",
