							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"",
									"const json = pm.response.json();",
									"pm.test('Response has token', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
									"pm.test('Response has username', () => pm.expect(json.username).to.eql(pm.collectionVariables.get('test_username')));",
									"pm.test('Response has role', () => pm.expect(json.role).to.be.a('string'));",
									"",
									"// Декодируем JWT и проверяем claims",
									"const payload = JSON.parse(atob(json.token.split('.')[1]));",
									"pm.test('JWT subject = username', () => pm.expect(payload.sub).to.eql(pm.collectionVariables.get('test_username')));",
									"pm.test('JWT has role claim', () => pm.expect(payload.role).to.exist);",
									"",
									"pm.collectionVariables.set('auth_token', json.token);"
								]
							}
						}
