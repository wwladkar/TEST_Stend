		{
			"name": "🔑 Security / JWT",
			"item": [
				{
					"name": "JWT — decode and verify claims",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const token = pm.collectionVariables.get('auth_token');",
									"pm.test('Token exists', () => pm.expect(token).to.be.a('string').and.not.empty);",
									"",
									"const parts = token.split('.');",
									"pm.test('JWT has 3 parts', () => pm.expect(parts.length).to.eql(3));",
									"",
									"const payload = JSON.parse(atob(parts[1]));",
									"pm.test('sub = username', () => pm.expect(payload.sub).to.eql(pm.collectionVariables.get('test_username')));",
									"pm.test('role claim exists', () => pm.expect(payload.role).to.exist);",
									"pm.test('iat exists', () => pm.expect(payload.iat).to.exist);",
									"pm.test('exp exists', () => pm.expect(payload.exp).to.exist);",
									"pm.test('exp > iat', () => pm.expect(payload.exp).to.be.greaterThan(payload.iat));"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Этот запрос не отправляется — тесты работают с уже сохранённым токеном из переменных коллекции."
					}
				},
				{
					"name": "JWT — wrong signing key (401)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Генерируем токен с другим ключом — не совпадёт с JWT_SECRET стенда",
									"const fakeToken = 'eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ0ZXN0Iiwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjk5OTk5OTk5OTl9.fake_signature_invalid';",
									"pm.collectionVariables.set('fake_token', fakeToken);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 401 or 403', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{fake_token}}", "type": "string" }]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/me",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "me"]
						}
					}
				},
				{
					"name": "JWT — no Bearer prefix (401)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.request.headers.upsert({ key: 'Authorization', value: pm.collectionVariables.get('auth_token') });",
									"// Убираем Bearer-авторизацию, чтобы не дублировать заголовок",
									"pm.request.auth = { type: 'noauth' };"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 401 or 403', () => {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/me",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "me"]
						}
					}
				},
				{
					"name": "JWT — role mismatch: token=ADMIN, DB=USER",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Сценарий: пользователь получил токен с role=USER,",
									"// затем админ сменил ему роль на ADMIN через /api/admin/users/{id}/role,",
									"// но старый токен всё ещё содержит role=USER.",
									"// Обратный сценарий: токен с ADMIN, но в БД — USER",
									"// Это возможно если подделать токен или если админ понизил роль,",
									"// а старый токен ещё жив.",
									"// Здесь проверяем: если в JWT role=ADMIN, SecurityFilter пропустит в /api/admin/**",
									"// независимо от того, что в БД.",
									"console.log('Этот тест требует ручной установки токена с role=ADMIN для USER-аккаунта.');",
									"console.log('Автоматизация: используйте admin_token для доступа к admin-эндпоинту, затем проверьте /api/users/me.');"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Если admin_token принадлежит тому же пользователю,",
									"// то /api/admin/users пройдёт (JWT=ADMIN), но /api/users/me покажет реальную роль из БД.",
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    const dbRole = json.role;",
									"    const token = pm.collectionVariables.get('admin_token');",
									"    if (token) {",
									"        const payload = JSON.parse(atob(token.split('.')[1]));",
									"        pm.test('JWT role ≠ DB role (desync documented)', () => {",
									"            // Если роли разные — это документирует десинхрон",
									"            if (payload.role !== dbRole) {",
									"                console.warn('⚠ JWT role=' + payload.role + ', DB role=' + dbRole + ' — desync!');",
									"            }",
									"        });",
									"    }",
									"} else {",
									"    pm.test('Admin token required for this test', () => pm.expect(true).to.eql(true));",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [{ "key": "token", "value": "{{admin_token}}", "type": "string" }]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/users/me",
							"host": ["{{base_url}}"],
							"path": ["api", "users", "me"]
						}
					}
				}
			]
		}
