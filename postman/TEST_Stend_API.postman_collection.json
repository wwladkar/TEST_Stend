					"name": "Register — success",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const ts = Date.now();",
									"pm.collectionVariables.set('test_username', 'pm_' + ts);",
									"pm.collectionVariables.set('test_email', 'pm_' + ts + '@test.stend');"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"",
									"const json = pm.response.json();",
									"pm.test('Response has token', () => pm.expect(json.token).to.be.a('string').and.not.empty);",
									"pm.test('Response has username', () => pm.expect(json.username).to.eql(pm.collectionVariables.get('test_username')));",
									"pm.test('Default role is USER', () => pm.expect(json.role).to.eql('USER'));",
									"",
									"pm.collectionVariables.set('auth_token', json.token);"
								]
							}
						}
					],
